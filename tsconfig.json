{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "lib": ["es2015", "es2017", "dom"],
    "noImplicitAny": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "es5",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
